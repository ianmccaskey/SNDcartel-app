# ─── Database ────────────────────────────────────────────────────────────────
# Neon serverless Postgres connection string
# Get this from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# Base URL of your app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# ─── Alchemy ──────────────────────────────────────────────────────────────────
# Get from: https://dashboard.alchemy.com → Apps → API Keys
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Get from: https://dashboard.alchemy.com → Webhooks → Signing Key
ALCHEMY_WEBHOOK_SIGNING_KEY=your_alchemy_webhook_signing_key_here

# ─── USDC Contract Addresses ──────────────────────────────────────────────────
USDC_CONTRACT_ETHEREUM=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
USDC_CONTRACT_POLYGON=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
USDC_CONTRACT_BASE=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# ─── Store Payment Wallet ─────────────────────────────────────────────────────
# The USDC wallet address customers send store purchases to
NEXT_PUBLIC_STORE_WALLET_ADDRESS=0xYourStoreWalletAddressHere

# ─── File Storage (Cloudflare R2 or Vercel Blob) ──────────────────────────────
# Option A: Cloudflare R2 (S3-compatible)
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key_id
# R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# R2_BUCKET_NAME=sndcartel-uploads
# R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# Option B: Vercel Blob
# BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
# RESEND_API_KEY=re_your_resend_api_key
# EMAIL_FROM=noreply@yourdomain.com
