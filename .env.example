# ─── Database ────────────────────────────────────────────────────────────────
# Neon serverless Postgres connection string.
# Get this from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# Base URL of your app (no trailing slash). In production this is the public URL.
NEXTAUTH_URL=http://localhost:3000

# ─── Alchemy (on-chain payment verification) ─────────────────────────────────
# Get from: https://dashboard.alchemy.com → Apps → API Keys
# If unset, Alchemy features silently disable (warn at startup).
ALCHEMY_API_KEY=

# Get from: https://dashboard.alchemy.com → Webhooks → Signing Key
# Required to validate the inbound /api/webhooks/alchemy POST.
ALCHEMY_WEBHOOK_SIGNING_KEY=

# ─── Store Payment Wallet (public, client-side) ──────────────────────────────
# The wallet address customers send store purchases to.
# Public — do not put any secret here.
NEXT_PUBLIC_STORE_WALLET_ADDRESS=0xYourStoreWalletAddressHere

# ─── DigitalOcean Spaces (S3-compatible) ─────────────────────────────────────
# Used by /api/admin/uploads for campaign images, tracking-label uploads, etc.
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=sndcartel-uploads
DO_SPACES_KEY=your_spaces_access_key
DO_SPACES_SECRET=your_spaces_secret_key
# Optional. If unset, the upload route falls back to
# https://<bucket>.<region>.cdn.digitaloceanspaces.com
DO_SPACES_CDN_ENDPOINT=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
# If RESEND_API_KEY is unset, lib/email.ts logs and skips sending (no-op).
RESEND_API_KEY=
# Optional override for the From address. Default is
# "SNDcartel <noreply@sndcartel.com>".
RESEND_FROM_ADDRESS=

# ─── Notes ────────────────────────────────────────────────────────────────────
# USDC contract addresses are hardcoded in lib/alchemy.ts — no env override.
# In production, set all of the above in DigitalOcean App Platform → Settings → App-Level Environment Variables.
